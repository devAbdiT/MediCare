generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PATIENT
  DOCTOR
  RECEPTIONIST
  ADMIN
  PHARMACIST
  LABTECH
}

enum AppointmentStatus {
  SCHEDULED
  PAYMENT_PENDING
  CHECKED_IN
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String?
  phone         String?
  role          Role     @default(PATIENT)
  gender        String?
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient      Patient?
  doctor       Doctor?
  receptionist Receptionist?
  admin        Admin?

  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Patient {
  id          String    @id @default(cuid())
  userId      String    @unique
  dateOfBirth DateTime?
  age         Int?
  bloodType   String?
  cardNumber  String?   @unique

  address           String?
  city              String?
  region            String?
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  patientStatus     PatientStatus @default(ACTIVE)
  insuranceProvider String?
  insurancePolicyNo String?
  insuranceCoverage String?
  insuranceExpiry   DateTime?

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  medicalRecords      MedicalRecord[]
  appointmentPayments AppointmentPayment[]
  allergies           Allergy[]
  conditions          MedicalCondition[]
  invoices            Invoice[]
  labOrders           LabOrder[]
  referrals           Referral[]

  @@map("patients")
}

model Doctor {
  id             String  @id @default(cuid())
  userId         String  @unique
  specialization String
  departmentId   String?
  consultationFee Decimal?
  bio            String?
  profilePhoto   String?

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  availabilities   DoctorAvailability[]
  referralsFrom    Referral[]           @relation("FromDoctor")
  referralsTo      Referral[]           @relation("ToDoctor")
  labOrders        LabOrder[]

  @@map("doctors")
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Receptionist {
  id     String @id @default(cuid())
  userId String @unique

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("receptionists")
}

enum AppointmentType {
  NEW_VISIT
  FOLLOW_UP
  CONSULTATION
  EMERGENCY
}

enum AppointmentPriority {
  NORMAL
  URGENT
  EMERGENCY
}

model Appointment {
  id             String  @id @default(cuid())
  patientId      String
  doctorId       String
  receptionistId String?

  dateTime        DateTime
  status          AppointmentStatus   @default(SCHEDULED)
  reason          String?
  appointmentType AppointmentType     @default(NEW_VISIT)
  priority        AppointmentPriority @default(NORMAL)
  checkedInAt     DateTime?
  queueNumber     Int?
  walkIn          Boolean             @default(false)
  chiefComplaint  String?
  noShowAt        DateTime?

  paymentStatus   AppointmentPaymentStatus @default(PENDING)
  paymentRequired Boolean                  @default(true)
  paidAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient      Patient               @relation(fields: [patientId], references: [id])
  doctor       Doctor                @relation(fields: [doctorId], references: [id])
  receptionist Receptionist?         @relation(fields: [receptionistId], references: [id])
  histories    AppointmentHistory[]
  reminders    AppointmentReminder[]
  payments     AppointmentPayment[]
  vitalSigns   VitalSigns?
  labOrders    LabOrder[]
  referrals    Referral[]
  invoice      Invoice?

  @@map("appointments")
}

model AppointmentReminder {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  reminderType String
  status       String
  message      String?

  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([appointmentId])
  @@index([status])
  @@index([sentAt])
  @@map("appointment_reminders")
}

model MedicalRecord {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?  @unique
  diagnosis     String
  prescription  String
  icdCode       String?
  notes         String?
  date          DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  prescriptions Prescription[]

  @@map("medical_records")
}

model Department {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  consultationFee Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors Doctor[]
  referrals Referral[]

  @@map("departments")
}

model AppointmentHistory {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  oldDateTime DateTime?
  newDateTime DateTime?

  oldStatus AppointmentStatus?
  newStatus AppointmentStatus?

  reason     String?
  actionType String?

  changedByUserId String?
  changedByName   String?
  changedByRole   String?

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@index([createdAt])
  @@map("appointment_histories")
}

model DoctorAvailability {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([dayOfWeek])
  @@map("doctor_availabilities")
}

enum AppointmentPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum AppointmentPaymentProvider {
  CHAPA
}

model AppointmentPayment {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  provider AppointmentPaymentProvider @default(CHAPA)
  status   AppointmentPaymentStatus   @default(PENDING)

  txRef       String  @unique
  chapaRefId  String?
  checkoutUrl String?

  amount      Decimal
  currency    String  @default("ETB")
  description String?

  initializedAt DateTime  @default(now())
  paidAt        DateTime?
  failedAt      DateTime?
  cancelledAt   DateTime?
  expiresAt     DateTime?

  rawInitializeResponse Json?
  rawVerifyResponse     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([patientId])
  @@index([status])
  @@index([txRef])
  @@map("appointment_payments")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  DECEASED
}

model Allergy {
  id          String          @id @default(cuid())
  patientId   String
  allergen    String
  severity    AllergySeverity @default(MILD)
  reaction    String?
  confirmedAt DateTime?
  patient     Patient @relation(fields:[patientId],references:[id],onDelete:Cascade)
  @@map("allergies")
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

model MedicalCondition {
  id          String   @id @default(cuid())
  patientId   String
  name        String
  icdCode     String?
  diagnosedAt DateTime?
  isActive    Boolean  @default(true)
  notes       String?
  patient     Patient @relation(fields:[patientId],references:[id],onDelete:Cascade)
  @@map("medical_conditions")
}

model Service {
  id           String          @id @default(cuid())
  name         String
  code         String          @unique
  category     ServiceCategory
  unitPrice    Decimal
  isActive     Boolean         @default(true)
  description  String?
  invoiceItems InvoiceItem[]
  createdAt    DateTime        @default(now())
  @@map("services")
}

enum ServiceCategory {
  CONSULTATION
  LAB
  PHARMACY
  PROCEDURE
  ROOM
  OTHER
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  patientId     String
  appointmentId String?       @unique
  totalAmount   Decimal
  discountAmt   Decimal       @default(0)
  paidAmount    Decimal       @default(0)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime?
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  patient       Patient       @relation(fields:[patientId],references:[id])
  appointment   Appointment?  @relation(fields:[appointmentId],references:[id])
  lineItems     InvoiceItem[]
  payments      Payment[]
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
  CANCELLED
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String?
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal
  totalPrice  Decimal
  invoice     Invoice  @relation(fields:[invoiceId],references:[id],onDelete:Cascade)
  service     Service? @relation(fields:[serviceId],references:[id])
  @@map("invoice_items")
}

model Payment {
  id           String        @id @default(cuid())
  invoiceId    String
  amount       Decimal
  method       PaymentMethod
  reference    String?
  receivedById String
  receivedAt   DateTime      @default(now())
  notes        String?
  invoice      Invoice       @relation(fields:[invoiceId],references:[id])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  CHAPA
  INSURANCE
  BANK_TRANSFER
  WAIVER
}

model VitalSigns {
  id               String      @id @default(cuid())
  appointmentId    String      @unique
  patientId        String
  bloodPressureSys Int?
  bloodPressureDia Int?
  temperature      Decimal?
  weight           Decimal?
  height           Decimal?
  pulseRate        Int?
  oxygenSaturation Decimal?
  respiratoryRate  Int?
  recordedById     String
  recordedAt       DateTime    @default(now())
  appointment      Appointment @relation(fields:[appointmentId],references:[id])
  @@map("vital_signs")
}

model Prescription {
  id              String        @id @default(cuid())
  medicalRecordId String
  drugName        String
  dose            String
  frequency       String
  duration        String
  route           String        @default("Oral")
  quantity        Int?
  instructions    String?
  medicalRecord   MedicalRecord @relation(fields:[medicalRecordId],references:[id],onDelete:Cascade)
  @@map("prescriptions")
}

model Referral {
  id             String          @id @default(cuid())
  appointmentId  String
  patientId      String
  fromDoctorId   String
  toDoctorId     String?
  toDepartmentId String?
  reason         String
  urgency        ReferralUrgency @default(ROUTINE)
  notes          String?
  status         ReferralStatus  @default(PENDING)
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  appointment    Appointment     @relation(fields:[appointmentId],references:[id])
  patient        Patient         @relation(fields:[patientId],references:[id])
  fromDoctor     Doctor          @relation("FromDoctor",fields:[fromDoctorId],references:[id])
  toDoctor       Doctor?         @relation("ToDoctor",fields:[toDoctorId],references:[id])
  toDepartment   Department?     @relation(fields:[toDepartmentId],references:[id])
  @@map("referrals")
}

enum ReferralUrgency {
  ROUTINE
  URGENT
  EMERGENCY
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userRole  String
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())
  @@index([entity,entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Drug {
  id           String          @id @default(cuid())
  name         String
  genericName  String?
  category     String
  form         DrugForm
  strength     String?
  unit         String
  reorderLevel Int             @default(10)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  stocks       DrugStock[]
  dispensings  DrugDispensing[]
  @@map("drugs")
}

enum DrugForm {
  TABLET
  CAPSULE
  LIQUID
  INJECTION
  CREAM
  INHALER
  OTHER
}

model DrugStock {
  id           String    @id @default(cuid())
  drugId       String
  batchNumber  String?
  quantity     Int
  expiryDate   DateTime?
  receivedAt   DateTime  @default(now())
  receivedById String?
  drug         Drug      @relation(fields:[drugId],references:[id],onDelete:Cascade)
  @@map("drug_stocks")
}

model DrugDispensing {
  id             String   @id @default(cuid())
  drugId         String
  prescriptionId String?
  patientId      String
  quantity       Int
  dispensedById  String
  dispensedAt    DateTime @default(now())
  notes          String?
  drug           Drug     @relation(fields:[drugId],references:[id])
  @@map("drug_dispensings")
}

model LabTestCatalogue {
  id             String     @id @default(cuid())
  name           String
  code           String     @unique
  category       String
  referenceRange String?
  unit           String?
  turnaroundHrs  Int?
  price          Decimal?
  isActive       Boolean    @default(true)
  labOrders      LabOrder[]
  @@map("lab_test_catalogues")
}

model LabOrder {
  id              String         @id @default(cuid())
  appointmentId   String
  patientId       String
  doctorId        String
  testCatalogueId String?
  testName        String
  urgency         LabUrgency     @default(ROUTINE)
  status          LabOrderStatus @default(ORDERED)
  sampleType      String?
  notes           String?
  orderedAt       DateTime       @default(now())
  appointment     Appointment    @relation(fields:[appointmentId],references:[id])
  patient         Patient        @relation(fields:[patientId],references:[id])
  doctor          Doctor         @relation(fields:[doctorId],references:[id])
  result          LabResult?
  testCatalogue   LabTestCatalogue? @relation(fields:[testCatalogueId],references:[id])
  @@map("lab_orders")
}

enum LabUrgency {
  ROUTINE
  URGENT
  STAT
}

enum LabOrderStatus {
  ORDERED
  SAMPLE_COLLECTED
  PROCESSING
  RESULTED
  CANCELLED
}

model LabResult {
  id             String   @id @default(cuid())
  labOrderId     String   @unique
  resultValue    String
  unit           String?
  referenceRange String?
  isAbnormal     Boolean  @default(false)
  interpretation String?
  enteredById    String
  enteredAt      DateTime @default(now())
  verifiedById   String?
  verifiedAt     DateTime?
  labOrder       LabOrder @relation(fields:[labOrderId],references:[id])
  @@map("lab_results")
}
